PORT=8090
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# Separate Gemini keys by use case.
GEMINI_API_KEY_FIREWALL=
GEMINI_API_KEY_RAG=
GEMINI_FIREWALL_MODEL=gemini-1.5-flash
GEMINI_RAG_MODEL=gemini-1.5-pro

# Groq keys and models for RAG.
GROQ_API_KEY=
GROQ_RAG_MODEL=llama-3.3-70b-versatile

# Database: memory, postgres, or mongo.
DATABASE_PROVIDER=memory
DATABASE_URL=postgres://user:password@localhost:5432/prompt_firewall
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=prompt_firewall

# Vector DB: memory, chroma, pinecone, or weaviate.
VECTOR_PROVIDER=memory
CHROMA_URL=http://localhost:8000
CHROMA_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=
WEAVIATE_URL=
WEAVIATE_API_KEY=

# LangSmith evaluation/tracing.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=prompt-injection-firewall

# Optional risk scoring provider override: openai, groq, or gemini.
RISK_PROVIDER=openai
# Optional Gemini-based, OpenAI-based, or Groq risk scorer for prompt/document evaluation.
GEMINI_RISK_API_KEY=
OPENAI_RISK_API_KEY=
OPENAI_RISK_MODEL=gpt-4o-mini
GROQ_API_KEY=gsk_...
GROQ_RISK_MODEL=openai/gpt-oss-20b # use openai/gpt-oss-20b if groq-4.3 access is unavailable
RISK_ENGINE_MODEL=gemini-1.5-flash

# n8n automation.
N8N_WEBHOOK_URL=
